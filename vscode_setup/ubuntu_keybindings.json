// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+m",
        "command": "workbench.action.createTerminalEditorSameGroup"
    },
    {
        "key": "ctrl+shift+m",
        "command": "workbench.action.createTerminalEditorSide"
    },
    {
        "key": "ctrl+w",
        "command": "deleteLeft",
        "when": "terminalFocus && terminal.active"
    },
    {
        "key": "ctrl+shift+d",
        "command": "git.openChange"
    },
    {
        "key": "alt+shift+d",
        "command": "git.openAllChanges"
    },
    {
        // Original: ctrl+k --> ctrl+q
        "key": "ctrl+shift+z",
        "command": "workbench.action.navigateToLastEditLocation"
    },
    {
        // Original: ctrl+k --> p
        "key": "alt+p",
        "command": "workbench.action.files.copyPathOfActiveFile"
    },
    {
        // Original: ctrl+k --> v
        "key": "alt+shift+v",
        "command": "markdown.showPreviewToSide"
    },
    {
        // Original: ctrl+shift+v
        "key": "alt+v",
        "command": "markdown.showPreview"
    },
    {
        // Original: ctrl+shift+a
        "key": "ctrl+shift+/",
        "command": "editor.action.blockComment"
    },
    {
        // Original: ctrl+shift+[
        "key": "ctrl+[",
        "command": "editor.fold"
    },
    {
        // Original: ctrl+shift+]
        "key": "ctrl+]",
        "command": "editor.unfold"
    },
    {
        // Original: ctrl+shift+e
        "key": "ctrl+e",
        "command": "workbench.view.explorer"
    },
    {
        // Original: ctrl+shift+l
        "key": "alt+l",
        "command": "editor.action.selectHighlights"
    },
    {
        // Original: ctrl+shift+k
        "key": "ctrl+shift+backspace",
        "command": "editor.action.deleteLines"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
    },
    {
        "key": "ctrl+shift+j",
        "command": "workbench.action.terminal.moveToEditor"
    },
    {
        "key": "ctrl+meta+left",
        "command": "workbench.action.decreaseViewSize"
    },
    {
        "key": "ctrl+meta+right",
        "command": "workbench.action.increaseViewSize"
    },
    {
        "key": "ctrl+meta+down",
        "command": "workbench.action.decreaseViewSize"
    },
    {
        "key": "ctrl+meta+up",
        "command": "workbench.action.increaseViewSize"
    },
    {
        "key": "ctrl+i",
        "command": "-inlineChat.start"
    },
    {
        "key": "ctrl+t e",
        "command": "timeline.focus",
    },
    {
        "key": "ctrl+t b",
        "command": "timeline.removeView",
    },
    {
        "key": "ctrl+t g",
        "command": "timeline.toggleExcludeSource:git-history",
    },
    {
        "key": "ctrl+t l",
        "command": "timeline.toggleExcludeSource:timeline.localHistory",
    },
    {
        "key": "ctrl+shift+1",
        "command": "workbench.action.focusFirstEditorGroup"
    },
    {
        "key": "ctrl+shift+2",
        "command": "workbench.action.focusSecondEditorGroup"
    },
    {
        "key": "ctrl+shift+3",
        "command": "workbench.action.focusThirdEditorGroup"
    },
    {
        "key": "ctrl+shift+4",
        "command": "workbench.action.focusFourthEditorGroup"
    },
    {
        "key": "ctrl+shift+5",
        "command": "workbench.action.focusFifthEditorGroup"
    },
    {
        "key": "ctrl+shift+6",
        "command": "workbench.action.focusSixthEditorGroup"
    },
    {
        "key": "ctrl+shift+7",
        "command": "workbench.action.focusSeventhEditorGroup"
    },
    {
        "key": "ctrl+shift+8",
        "command": "workbench.action.focusEighthEditorGroup"
    },
    {
        "key": "ctrl+1",
        "command": "workbench.action.openEditorAtIndex1"
    },
    {
        "key": "ctrl+2",
        "command": "workbench.action.openEditorAtIndex2"
    },
    {
        "key": "ctrl+3",
        "command": "workbench.action.openEditorAtIndex3"
    },
    {
        "key": "ctrl+4",
        "command": "workbench.action.openEditorAtIndex4"
    },
    {
        "key": "ctrl+5",
        "command": "workbench.action.openEditorAtIndex5"
    },
    {
        "key": "ctrl+6",
        "command": "workbench.action.openEditorAtIndex6"
    },
    {
        "key": "ctrl+7",
        "command": "workbench.action.openEditorAtIndex7"
    },
    {
        "key": "ctrl+8",
        "command": "workbench.action.openEditorAtIndex8"
    },
    {
        "key": "ctrl+9",
        "command": "workbench.action.openEditorAtIndex9"
    },
    {
        "key": "ctrl+tab",
        "command": "workbench.action.nextEditorInGroup"
    },
    {
        "key": "ctrl+shift+tab",
        "command": "workbench.action.previousEditorInGroup"
    },
    {
        "key": "ctrl+alt+f",
        "command": "editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
    },
    {
        "key": "ctrl+g",
        "command": "editor.action.nextMatchFindAction",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+shift+g",
        "command": "editor.action.previousMatchFindAction",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+meta+g",
        "command": "editor.action.replaceOne",
        "when": "editorFocus && findWidgetVisible"
    },
    {
        "key": "ctrl+g",
        "command": "search.action.focusNextSearchResult",
        "when": "searchViewletVisible && hasSearchResult"
    },
    {
        "key": "ctrl+shift+g",
        "command": "search.action.focusPreviousSearchResult",
        "when": "searchViewletVisible && hasSearchResult"
    },
    {
        "key": "alt+ctrl+f",
        "command": "workbench.action.replaceInFiles",
        "when": "searchViewletVisible && hasSearchResult"
    },
    {
        "key": "alt+c",
        "command": "toggleSearchCaseSensitive",
        "when": "searchViewletVisible"
    },
    {
        "key": "alt+r",
        "command": "toggleSearchRegex",
        "when": "searchViewletVisible"
    },
    {
        "key": "ctrl+enter",
        "command": "search.action.replaceAll",
        "when": "replaceActive && searchViewletVisible && !findWidgetVisible"
    },
    {
        "key": "ctrl+meta+g",
        "command": "search.action.replace",
        "when": "searchViewletVisible",
    },
]