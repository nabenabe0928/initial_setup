[
    {
        "key": "cmd+y",
        "command": "redo",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+shift+up",
        "command": "editor.action.insertCursorAbove",
        "when": "editorTextFocus || terminalFocus"
    },
    {
        "key": "cmd+shift+down",
        "command": "editor.action.insertCursorBelow",
        "when": "editorTextFocus || terminalFocus"
    },
    {
        "key": "cmd+w",
        "command": "-workbench.action.closeActiveEditor",
        "when": "terminalFocus"
    },
    {
        "key": "cmd+w",
        "command": "workbench.action.terminal.sendSequence",
        "when": "terminalFocus",
        "args": {
            "text": "\u0017"
        }
    },
    {
        "key": "cmd+`",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
    },
    {
        "key": "cmd+j",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
    },
    {
        "key": "cmd+shift+j",
        "command": "workbench.action.terminal.moveToEditor"
    },
    {
        "key": "cmd+d",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u0004"
        },
        "when": "terminalFocus"
    },
    {
        "key": "cmd+backspace",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u0017"
        },
        "when": "terminalFocus"
    },
    {
        "key": "cmd+r",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u0012"
        },
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+home",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": ""
        },
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+end",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": ""
        },
        "when": "terminalFocus"
    },
    {
        "key": "cmd+c",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u0003"
        },
        "when": "terminalFocus"
    },
    {
        "key": "cmd+shift+c",
        "command": "workbench.action.terminal.copySelection",
        "when": "terminalFocus"
    },
    {
        "key": "cmd+shift+v",
        "command": "workbench.action.terminal.paste",
        "when": "terminalFocus"
    },
    {
        "key": "backspace",
        "command": "moveFileToTrash",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "f2",
        "command": "renameFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "shift+cmd+s",
        "command": "opensshremotes.openEmptyWindow"
    },
    {
        "key": "cmd+shift+m",
        "command": "workbench.action.createTerminalEditorSide"
    },
    {
        "key": "cmd+up",
        "command": "scrollLineUp"
    },
    {
        "key": "cmd+down",
        "command": "scrollLineDown"
    },
    {
        "key": "cmd+shift+d",
        "command": "git.openChange"
    },
    {
        "key": "alt+shift+d",
        "command": "git.openAllChanges"
    },
    {
        "key": "cmd+shift+z",
        "command": "workbench.action.navigateToLastEditLocation"
    },
    {
        "key": "alt+p",
        "command": "workbench.action.files.copyPathOfActiveFile"
    },
    {
        "key": "alt+shift+v",
        "command": "markdown.showPreviewToSide"
    },
    {
        "key": "alt+v",
        "command": "markdown.showPreview"
    },
    {
        "key": "cmd+[",
        "command": "editor.fold"
    },
    {
        "key": "cmd+]",
        "command": "editor.unfold"
    },
    {
        "key": "cmd+e",
        "command": "workbench.view.explorer"
    },
    {
        "key": "alt+l",
        "command": "editor.action.selectHighlights"
    },
    {
        "key": "cmd+backspace",
        "command": "deleteWordLeft"
    },
    {
        "key": "cmd+shift+backspace",
        "command": "editor.action.deleteLines"
    },
    {
        "key": "alt+c",
        "command": "toggleFindCaseSensitive"
    },
    {
        "key": "cmd+m",
        "command": "workbench.action.createTerminalEditorSameGroup"
    },
    {
        "key": "cmd+shift+/",
        "command": "editor.action.blockComment"
    },
    {
        "key": "cmd+ctrl+left",
        "command": "workbench.action.decreaseViewSize"
    },
    {
        "key": "cmd+ctrl+right",
        "command": "workbench.action.increaseViewSize"
    },
    {
        "key": "cmd+ctrl+down",
        "command": "workbench.action.decreaseViewSize"
    },
    {
        "key": "cmd+ctrl+up",
        "command": "workbench.action.increaseViewSize"
    },
    {
        "key": "cmd+i",
        "command": "-inlineChat.start"
    },
    {
        "key": "cmd+shift+i",
        "command": "-workbench.action.chat.open"
    },
    {
        "key": "cmd+t e",
        "command": "timeline.focus",
    },
    {
        "key": "cmd+t b",
        "command": "timeline.removeView",
    },
    // Timeline feature in MacOS is limited compared to the Linux version.
    // {
    //     "key": "cmd+t g",
    //     "command": "timeline.toggleExcludeSource:git-history",
    // },
    // {
    //     "key": "cmd+t l",
    //     "command": "timeline.toggleExcludeSource:timeline.localHistory",
    // },
]