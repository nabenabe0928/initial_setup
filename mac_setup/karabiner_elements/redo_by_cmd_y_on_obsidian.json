{
    "description": "Map Cmd+Y to Cmd+Shift+Z in Obsidian only",
    "manipulators": [
        {
            "conditions": [
                {
                    "bundle_identifiers": [
                        "^md\\.obsidian$"
                    ],
                    "type": "frontmost_application_if"
                }
            ],
            "from": {
                "key_code": "y",
                "modifiers": {
                    "mandatory": [
                        "command"
                    ]
                }
            },
            "to": [
                {
                    "key_code": "z",
                    "modifiers": [
                        "command",
                        "shift"
                    ]
                }
            ],
            "type": "basic"
        }
    ]
}